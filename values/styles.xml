<resources>
    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here -->
        <item name="colorPrimary">#1A237E</item>
        <item name="colorPrimaryDark">#0D175E</item>
        <item name="colorAccent">#FF9800</item>
    </style>

    <!-- Calendar Date Text Style -->
    <style name="CalendarDateText" parent="android:TextAppearance.DeviceDefault">
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Calendar Week Day Text Style -->
    <style name="CalendarWeekDayText" parent="android:TextAppearance.DeviceDefault">
        <item name="android:textColor">#1A237E</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>