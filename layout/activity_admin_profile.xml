<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5E6E8">

    <!-- Header - Wine Gradient -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@drawable/gradient_red_wine"
        android:paddingHorizontal="12dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="⬅️"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:gravity="center"
            android:background="#33FFFFFF"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Admin Profile"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Empty view for balance -->
        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <!-- ScrollView untuk content yang panjang -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FDF1F2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Profile Circle -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="100dp">

                        <LinearLayout
                            android:id="@+id/profileCircle"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:background="@drawable/circle_wine_bg"
                            android:gravity="center"
                            android:layout_centerHorizontal="true">

                            <TextView
                                android:id="@+id/tvProfileIcon"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="👤"
                                android:textSize="52sp"
                                android:textColor="@android:color/white" />
                        </LinearLayout>
                    </RelativeLayout>

                    <!-- Admin Name dengan Edit Button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:id="@+id/tvAdminName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Admin Name"
                            android:textColor="#722F37"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/btnEdit"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="✏️"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:background="@drawable/circle_gold_bg"
                            android:textColor="#722F37"
                            android:layout_marginStart="8dp"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <!-- Admin ID Chip -->
                    <TextView
                        android:id="@+id/tvAdminId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="ADM-2026-001"
                        android:textColor="#B5A36A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="#F3E3E2"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="20dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F3E3E2"
                        android:layout_marginBottom="20dp" />

                    <!-- Info Card - Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EMAIL"
                        android:textColor="#722F37"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#F3E3E2"
                        android:padding="4dp"
                        android:layout_marginBottom="16dp"
                        android:elevation="2dp">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="48dp"
                            android:text="📧"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:textColor="#722F37" />

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="admin@email.com"
                            android:textColor="#722F37"
                            android:textSize="15sp"
                            android:gravity="center_vertical"
                            android:background="@null"
                            android:paddingStart="8dp" />
                    </LinearLayout>

                    <!-- Info Card - Phone -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHONE"
                        android:textColor="#722F37"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#F3E3E2"
                        android:padding="4dp"
                        android:layout_marginBottom="20dp"
                        android:elevation="2dp">

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="48dp"
                            android:text="📞"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:textColor="#722F37" />

                        <TextView
                            android:id="@+id/tvPhone"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="012-345 6789"
                            android:textColor="#722F37"
                            android:textSize="15sp"
                            android:gravity="center_vertical"
                            android:background="@null"
                            android:paddingStart="8dp" />
                    </LinearLayout>

                    <!-- Edit Mode Container -->
                    <LinearLayout
                        android:id="@+id/editFieldsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:background="#F3E3E2"
                        android:padding="16dp"
                        android:layout_marginBottom="16dp"
                        android:elevation="2dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EDIT FULL NAME"
                            android:textColor="#722F37"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_marginBottom="4dp" />

                        <EditText
                            android:id="@+id/etFullName"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="#FDF1F2"
                            android:padding="12dp"
                            android:text="Admin Name"
                            android:textSize="15sp"
                            android:textColor="#722F37"
                            android:layout_marginBottom="12dp" />

                        <!-- Edit Mode Buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnSave"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="6dp"
                                android:text="💾 SAVE"
                                android:textAllCaps="false"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/button_wine_gradient"
                                android:textColor="@android:color/white" />

                            <Button
                                android:id="@+id/btnCancel"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                android:text="✖ CANCEL"
                                android:textAllCaps="false"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="#F3E3E2"
                                android:textColor="#FFFFFF" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Change Password Button -->
                    <Button
                        android:id="@+id/btnChangePassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="🔑 Change Password"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:background="@drawable/button_gold"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="8dp"
                        android:elevation="2dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Logout Button (Optional) -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="🚪 Logout"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/button_wine_gradient"
                android:textColor="@android:color/white"
                android:elevation="4dp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>