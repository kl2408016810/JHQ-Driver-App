<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5E6E8">

    <!-- Header dengan Back Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@drawable/gradient_red_wine"
        android:paddingHorizontal="12dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="⬅️"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:gravity="center"
            android:background="#33FFFFFF"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Check In"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Location Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FDF1F2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvCurrentLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 JHQ Main Yard, Johor"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#722F37"
                    android:layout_marginBottom="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3E3E2"
                    android:layout_marginVertical="8dp" />

                <TextView
                    android:id="@+id/tvShiftStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ Ready to Check In"
                    android:textSize="14sp"
                    android:textColor="#8B4C4F" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Check In Button - Only Button -->
        <Button
            android:id="@+id/btnCheckIn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="CHECK IN"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/button_wine_gradient"
            android:textColor="@android:color/white"
            android:layout_marginTop="16dp" />

        <!-- Info Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="You can only check in once per day"
            android:textColor="#8B4C4F"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>