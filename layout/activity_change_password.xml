<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5E6E8">

    <!-- Header - Wine Gradient -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@drawable/gradient_red_wine"
        android:paddingHorizontal="12dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:padding="8dp"
            app:tint="@android:color/white"
            android:background="#33FFFFFF"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Change Password"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <!-- Form Card - Wine Theme -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FDF1F2">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Lock Icon -->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/circle_wine_bg"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="40sp"
                    android:textColor="@android:color/white" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Change Password"
                android:textColor="#722F37"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <!-- Current Password with Toggle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CURRENT PASSWORD"
                android:textColor="#722F37"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F3E3E2"
                android:padding="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/ivCurrentLock"
                    android:layout_width="40dp"
                    android:layout_height="48dp"
                    android:text="🔒"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:textColor="#722F37"
                    android:layout_alignParentStart="true" />

                <EditText
                    android:id="@+id/etCurrentPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_toStartOf="@id/ivCurrentToggle"
                    android:layout_toEndOf="@id/ivCurrentLock"
                    android:hint="Enter current password"
                    android:inputType="textPassword"
                    android:background="@null"
                    android:paddingHorizontal="8dp"
                    android:textSize="14sp"
                    android:textColor="#722F37"
                    android:textColorHint="#B5A36A"/>

                <TextView
                    android:id="@+id/ivCurrentToggle"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:text="👁️"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:textColor="#722F37" />
            </RelativeLayout>

            <!-- New Password with Toggle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW PASSWORD"
                android:textColor="#722F37"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F3E3E2"
                android:padding="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/ivNewLock"
                    android:layout_width="40dp"
                    android:layout_height="48dp"
                    android:text="🔒"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:textColor="#722F37"
                    android:layout_alignParentStart="true" />

                <EditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_toStartOf="@id/ivNewToggle"
                    android:layout_toEndOf="@id/ivNewLock"
                    android:hint="Min 6 characters"
                    android:inputType="textPassword"
                    android:background="@null"
                    android:paddingHorizontal="8dp"
                    android:textSize="14sp"
                    android:textColor="#722F37"
                    android:textColorHint="#B5A36A" />

                <TextView
                    android:id="@+id/ivNewToggle"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:text="👁️"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:textColor="#722F37" />
            </RelativeLayout>

            <!-- Confirm Password with Toggle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONFIRM PASSWORD"
                android:textColor="#722F37"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F3E3E2"
                android:padding="4dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/ivConfirmLock"
                    android:layout_width="40dp"
                    android:layout_height="48dp"
                    android:text="🔒"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:textColor="#722F37"
                    android:layout_alignParentStart="true" />

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_toStartOf="@id/ivConfirmToggle"
                    android:layout_toEndOf="@id/ivConfirmLock"
                    android:hint="Re-enter password"
                    android:inputType="textPassword"
                    android:background="@null"
                    android:paddingHorizontal="8dp"
                    android:textSize="14sp"
                    android:textColor="#722F37"
                    android:textColorHint="#B5A36A"/>

                <TextView
                    android:id="@+id/ivConfirmToggle"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:text="👁️"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:textColor="#722F37" />
            </RelativeLayout>

            <!-- Update Button - Wine Gradient -->
            <Button
                android:id="@+id/btnUpdatePassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Update Password"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/button_wine_gradient"
                android:textColor="@android:color/white"
                android:layout_marginBottom="16dp"
                android:elevation="2dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Info Card - Wine Theme -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FDF1F2">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="ℹ️"
                    android:textSize="16sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password Requirements:"
                    android:textColor="#722F37"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Minimum 6 characters"
                android:textColor="#8B4C4F"
                android:textSize="13sp"
                android:layout_marginBottom="4dp"
                android:layout_marginStart="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Use letters and numbers"
                android:textColor="#8B4C4F"
                android:textSize="13sp"
                android:layout_marginBottom="4dp"
                android:layout_marginStart="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ Must match confirmation"
                android:textColor="#8B4C4F"
                android:textSize="13sp"
                android:layout_marginStart="32dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>