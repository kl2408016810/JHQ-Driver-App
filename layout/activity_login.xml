<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_red_wine"
    tools:context=".LoginActivity">

    <!-- Logo dengan Wine Theme -->
    <LinearLayout
    android:id="@+id/ivLogo"
    android:layout_width="80dp"
    android:layout_height="80dp"
    android:background="@drawable/circle_gold_bg"
    android:gravity="center"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    android:layout_marginTop="60dp">

<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="🚚"
    android:textSize="48sp"
    android:textColor="#722F37" />
</LinearLayout>

    <!-- App Title -->
<TextView
android:id="@+id/tvAppTitle"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="JHQ DRIVER APP"
android:textColor="@android:color/white"
android:textSize="28sp"
android:textStyle="bold"
android:letterSpacing="0.05"
app:layout_constraintEnd_toEndOf="parent"
app:layout_constraintStart_toStartOf="parent"
app:layout_constraintTop_toBottomOf="@id/ivLogo"
android:layout_marginTop="12dp" />

    <!-- White Card Container - Light Wine -->
    <androidx.cardview.widget.CardView
    android:id="@+id/cardLogin"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginTop="32dp"
    app:cardCornerRadius="30dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="#FDF1F2"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/tvAppTitle">

<LinearLayout
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:orientation="vertical"
android:padding="20dp">

<!-- Welcome Text - Wine -->
<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Welcome Back!"
    android:textColor="#722F37"
    android:textSize="28sp"
    android:textStyle="bold"
    android:layout_marginBottom="4dp" />

<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Sign in to continue"
    android:textColor="#8B4C4F"
    android:textSize="15sp"
    android:layout_marginBottom="24dp" />

<!-- Email Field -->
<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="EMAIL"
    android:textColor="#722F37"
    android:textSize="11sp"
    android:textStyle="bold"
    android:letterSpacing="0.05"
    android:layout_marginBottom="4dp" />

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#F3E3E2"
    android:padding="4dp"
    android:layout_marginBottom="16dp">

    <TextView
        android:layout_width="40dp"
        android:layout_height="48dp"
        android:text="📧"
        android:textSize="20sp"
        android:gravity="center"
        android:textColor="#722F37" />

    <EditText
        android:id="@+id/etUsername"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:hint="Enter your email"
        android:inputType="textEmailAddress"
        android:background="@null"
        android:textSize="14sp"
        android:textColor="#722F37"
        android:textColorHint="#B5A36A" />
</LinearLayout>

<!-- Password Field -->
<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="PASSWORD"
    android:textColor="#722F37"
    android:textSize="11sp"
    android:textStyle="bold"
    android:letterSpacing="0.05"
    android:layout_marginBottom="4dp" />

<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F3E3E2"
    android:padding="4dp"
    android:layout_marginBottom="12dp">

    <TextView
        android:id="@+id/ivPasswordIcon"
        android:layout_width="40dp"
        android:layout_height="48dp"
        android:text="🔒"
        android:textSize="20sp"
        android:gravity="center"
        android:textColor="#722F37"
        android:layout_alignParentStart="true" />

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_toStartOf="@id/ivPasswordToggle"
        android:layout_toEndOf="@id/ivPasswordIcon"
        android:hint="Enter your password"
        android:inputType="textPassword"
        android:background="@null"
        android:textSize="14sp"
        android:textColor="#722F37"
        android:textColorHint="#B5A36A"
        android:paddingStart="8dp"
        android:paddingEnd="8dp" />

    <TextView
        android:id="@+id/ivPasswordToggle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentEnd="true"
        android:text="👁️"
        android:textSize="22sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:textColor="#722F37" />
</RelativeLayout>

    <!-- Remember Me & Forgot Password -->
    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginBottom="24dp">

    <CheckBox
        android:id="@+id/cbRememberMe"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Remember me"
        android:textColor="#722F37"
        android:textSize="14sp"
        android:buttonTint="#722F37" />

</LinearLayout>

<!-- Sign In Button - Wine Gradient -->
<Button
    android:id="@+id/btnLogin"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    android:text="SIGN IN"
    android:textAllCaps="false"
    android:textSize="16sp"
    android:textStyle="bold"
    android:background="@drawable/button_wine_gradient"
    android:textColor="@android:color/white"
    app:cornerRadius="25dp"
    android:layout_marginBottom="16dp"
    android:elevation="4dp" />

<!-- Sign Up Link -->
<TextView
    android:id="@+id/tvSignUp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Don't have an account? Sign Up"
    android:textColor="#722F37"
    android:textSize="14sp"
    android:textStyle="bold"
    android:layout_gravity="center_horizontal"
    android:layout_marginBottom="16dp" />

</LinearLayout>


    </androidx.cardview.widget.CardView>

    <!-- Test Login (Hidden) -->
    <TextView
    android:id="@+id/tvTestLogin"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Test Account"
    android:textColor="#E8C5C0"
    android:textSize="12sp"
    android:visibility="gone"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="16dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>