<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5E6E8"
    tools:context=".SignUpActivity">

    <!-- Header dengan Wine Gradient -->
    <LinearLayout
    android:id="@+id/headerGradient"
    android:layout_width="match_parent"
    android:layout_height="140dp"
    android:orientation="vertical"
    android:background="@drawable/gradient_red_wine"
    android:padding="20dp"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

<!-- Back Button dalam header -->
<TextView
    android:id="@+id/btnBack"
    android:layout_width="40dp"
    android:layout_height="40dp"
    android:text="⬅️"
    android:textColor="@android:color/white"
    android:textSize="24sp"
    android:gravity="center"
    android:background="#33FFFFFF"
    android:clickable="true"
    android:focusable="true" />

<!-- Title dalam header -->
<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Create Account"
    android:textColor="@android:color/white"
    android:textSize="28sp"
    android:textStyle="bold"
    android:layout_marginTop="8dp"
    android:layout_gravity="center_horizontal" />

<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Join JHQ Driver App"
    android:textColor="#E8C5C0"
    android:textSize="14sp"
    android:layout_gravity="center_horizontal" />
</LinearLayout>

    <!-- Form Card - Light Wine (Bukan Putih) -->
    <androidx.cardview.widget.CardView
    android:id="@+id/cardSignUp"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="-30dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#FDF1F2"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/headerGradient"
    app:layout_constraintBottom_toBottomOf="parent"
    android:layout_marginBottom="24dp">

    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="22dp">

<!-- Full Name dengan Wine Label -->
<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="FULL NAME"
    android:textColor="#722F37"
    android:textSize="11sp"
    android:textStyle="bold"
    android:letterSpacing="0.05"
    android:layout_marginBottom="4dp" />

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#F3E3E2"
    android:padding="4dp">

    <TextView
        android:layout_width="40dp"
        android:layout_height="48dp"
        android:text="👤"
        android:textSize="20sp"
        android:gravity="center"
        android:textColor="#722F37" />

    <EditText
        android:id="@+id/etFullName"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:hint="Enter your full name"
        android:textColorHint="#B5A36A"
        android:inputType="textPersonName"
        android:background="@null"
        android:textSize="14sp"
        android:textColor="#722F37" />
</LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

<!-- Email -->
<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="EMAIL"
    android:textColor="#722F37"
    android:textSize="11sp"
    android:textStyle="bold"
    android:letterSpacing="0.05"
    android:layout_marginBottom="4dp" />

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#F3E3E2"
    android:padding="4dp">

    <TextView
        android:layout_width="40dp"
        android:layout_height="48dp"
        android:text="📧"
        android:textSize="20sp"
        android:gravity="center"
        android:textColor="#722F37" />

    <EditText
        android:id="@+id/etEmail"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:hint="email@example.com"
        android:textColorHint="#B5A36A"
        android:inputType="textEmailAddress"
        android:background="@null"
        android:textSize="14sp"
        android:textColor="#722F37" />
</LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

<!-- Phone -->
<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="PHONE NUMBER"
    android:textColor="#722F37"
    android:textSize="11sp"
    android:textStyle="bold"
    android:letterSpacing="0.05"
    android:layout_marginBottom="4dp" />

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#F3E3E2"
    android:padding="4dp">

    <TextView
        android:layout_width="40dp"
        android:layout_height="48dp"
        android:text="📱"
        android:textSize="20sp"
        android:gravity="center"
        android:textColor="#722F37" />

    <EditText
        android:id="@+id/etPhone"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:hint="012-3456789"
        android:textColorHint="#B5A36A"
        android:inputType="phone"
        android:background="@null"
        android:textSize="14sp"
        android:textColor="#722F37" />
</LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

<!-- Role Selection dengan Wine Theme -->
<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="REGISTER AS"
    android:textColor="#722F37"
    android:textSize="11sp"
    android:textStyle="bold"
    android:letterSpacing="0.05"
    android:layout_marginBottom="8dp" />

<RadioGroup
    android:id="@+id/radioGroupRole"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#F3E3E2"
    android:padding="8dp">

    <RadioButton
        android:id="@+id/radioDriver"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Driver"
        android:textSize="14sp"
        android:textColor="#722F37"
        android:checked="true"
        android:buttonTint="#722F37" />

    <RadioButton
        android:id="@+id/radioAdmin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Admin"
        android:textSize="14sp"
        android:textColor="#722F37"
        android:buttonTint="#722F37" />
</RadioGroup>

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

<!-- Password -->
<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="PASSWORD"
    android:textColor="#722F37"
    android:textSize="11sp"
    android:textStyle="bold"
    android:letterSpacing="0.05"
    android:layout_marginBottom="4dp" />

<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F3E3E2"
    android:padding="4dp">

    <TextView
        android:id="@+id/ivPasswordIcon"
        android:layout_width="40dp"
        android:layout_height="48dp"
        android:text="🔒"
        android:textSize="20sp"
        android:gravity="center"
        android:textColor="#722F37"
        android:layout_alignParentStart="true" />

    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_toStartOf="@id/ivPasswordToggle"
        android:layout_toEndOf="@id/ivPasswordIcon"
        android:background="@null"
        android:hint="Create your password"
        android:inputType="textPassword"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:textColor="#722F37"
        android:textColorHint="#B5A36A"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/ivPasswordToggle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentEnd="true"
        android:text="👁️"
        android:textSize="22sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:textColor="#722F37" />
</RelativeLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

<!-- Confirm Password -->
<TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="CONFIRM PASSWORD"
    android:textColor="#722F37"
    android:textSize="11sp"
    android:textStyle="bold"
    android:letterSpacing="0.05"
    android:layout_marginBottom="4dp" />

<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F3E3E2"
    android:padding="4dp">

    <TextView
        android:id="@+id/ivConfirmIcon"
        android:layout_width="40dp"
        android:layout_height="48dp"
        android:text="🔒"
        android:textSize="20sp"
        android:gravity="center"
        android:textColor="#722F37"
        android:layout_alignParentStart="true" />

    <EditText
        android:id="@+id/etConfirmPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_toStartOf="@id/ivConfirmPasswordToggle"
        android:layout_toEndOf="@id/ivConfirmIcon"
        android:hint="Re-enter password"
        android:textColorHint="#B5A36A"
        android:inputType="textPassword"
        android:background="@null"
        android:textSize="14sp"
        android:textColor="#722F37"
        android:paddingStart="8dp"
        android:paddingEnd="8dp" />

    <TextView
        android:id="@+id/ivConfirmPasswordToggle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentEnd="true"
        android:text="👁️"
        android:textSize="22sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:textColor="#722F37" />
</RelativeLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

<!-- Register Button - Wine Gradient -->
<Button
    android:id="@+id/btnRegister"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:text="CREATE ACCOUNT"
    android:textAllCaps="false"
    android:textSize="14sp"
    android:textStyle="bold"
    android:background="@drawable/button_wine_gradient"
    android:textColor="@android:color/white"
    android:layout_marginBottom="14dp"
    android:elevation="4dp" />

<!-- Login Link - Gold Accent -->
<TextView
    android:id="@+id/tvLogin"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Already have an account? Login"
    android:textColor="#B5A36A"
    android:textSize="16sp"
    android:textStyle="bold"
    android:layout_gravity="center_horizontal" />

</LinearLayout>
    </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>