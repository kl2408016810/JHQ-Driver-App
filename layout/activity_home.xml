<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF8F7">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <!-- Header dengan Red Wine Gradient -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            android:backgroundTint="#722F37">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/gradient_red_wine"
                android:padding="20dp">

                <!-- Welcome Text dengan Gold -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back,"
                    android:textColor="#E8C5C0"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-light" />

                <TextView
                    android:id="@+id/tvDriverName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ahmad Driver"
                    android:textColor="@android:color/white"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp"
                    android:letterSpacing="0.03" />

                <!-- Location Chip dengan Gold Border -->
                <TextView
                    android:id="@+id/tvCurrentLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 JHQ Main Yard, Johor"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:background="@drawable/bg_location_chip"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:drawablePadding="8dp"
                    android:elevation="2dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Shift Status Card - Floating dengan Gold Accent -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-30dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Status Row dengan Gold Dot -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Shift Status"
                        android:textColor="#6B4E4F"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvShiftStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● Active"
                        android:textColor="#722F37"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="#F3E3E2"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Check In/Out Buttons - Red Wine Theme -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Check In - Wine Gradient -->
                    <LinearLayout
                        android:id="@+id/btnCheckIn"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_checkout_wine"
                        android:clickable="true"
                        android:focusable="true"
                        android:enabled="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="✅"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:background="#FFFFFF"
                            android:elevation="4dp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CHECK IN"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Start shift"
                            android:textColor="#F2D9D7"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <!-- Check Out - Dark Wine -->
                    <LinearLayout
                        android:id="@+id/btnCheckOut"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_checkout_wine"
                        android:clickable="true"
                        android:focusable="true"
                        android:enabled="true"
                        android:foreground="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="⬅️"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:background="#FFFFFF"
                            android:elevation="4dp"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CHECK OUT"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="End shift"
                            android:textColor="#F2D9D7"
                            android:textSize="9sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Today's Stats Card - Elegan -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Today's Performance"
                    android:textColor="#722F37"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="20dp"
                    android:drawablePadding="8dp" />

                <!-- 3 Stats Cards dengan Wine Palette -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Hours - Light Wine -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#F9F0EF"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="⏰"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:background="#722F37"
                            android:textColor="@android:color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvHoursWorked"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="#722F37"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hours"
                            android:textColor="#8B4C4F"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Loads - Rose Wine -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#F9F0EF"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="📦"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:background="#8B4C4F"
                            android:textColor="@android:color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvLoadsToday"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#722F37"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loads"
                            android:textColor="#8B4C4F"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Earnings - Gold Accent -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#F9F0EF"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:text="💰"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:background="#B5A36A"
                            android:textColor="@android:color/white"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvEarnings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RM0"
                            android:textColor="#722F37"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Earned"
                            android:textColor="#8B4C4F"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Progress Bar dengan Wine Theme -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Daily Target"
                            android:textColor="#8B4C4F"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvLoadsProgress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0/5 loads"
                            android:textColor="#722F37"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progressLoads"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:progress="0"
                        android:max="20"
                        android:progressTint="#722F37"
                        android:progressBackgroundTint="#F3E3E2" />
                </LinearLayout>

                <!-- Divider dengan Gold -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F3E3E2"
                    android:layout_marginVertical="16dp" />

                <!-- Career Total dengan Gold Icon -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F9F0EF"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:text="🏆"
                        android:textSize="22sp"
                        android:gravity="center"
                        android:background="#FFFFFF"
                        android:elevation="2dp"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Career Total"
                            android:textColor="#8B4C4F"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvTotalCareerLoads"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 loads"
                            android:textColor="#722F37"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Quick Actions - Wine Theme -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Menu"
            android:textColor="#722F37"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <!-- Tasks -->
            <LinearLayout
                android:id="@+id/btnDailyTasks"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_quick_action_wine"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tasks"
                    android:textColor="#722F37"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Chat dengan Badge -->
            <RelativeLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp">

                <LinearLayout
                    android:id="@+id/btnChat"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_quick_action_wine"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💬"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chat"
                        android:textColor="#722F37"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Badge untuk unread messages -->
                <TextView
                    android:id="@+id/badgeChat"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="5dp"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/badge_red"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:visibility="gone" />
            </RelativeLayout>

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/btnProfile"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_quick_action_wine"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="24sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textColor="#722F37"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ===== LOGOUT BUTTON - TAMBAH SINI ===== -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_margin="16dp"
            android:text="🚪 Logout"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/button_wine_gradient"
            android:textColor="@android:color/white"
            android:elevation="4dp" />

        <!-- Spacer bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="10dp" />

    </LinearLayout>
</ScrollView>