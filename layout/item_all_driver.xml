<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FDF1F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Driver Avatar - Left Side (Bulat Sempurna) -->
        <LinearLayout
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/circle_wine_bg"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/tvDriverInitial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Driver Details - Middle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Name Row -->
            <TextView
                android:id="@+id/tvDriverName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Driver Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#722F37"
                android:layout_marginBottom="4dp" />

            <!-- ID with Icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp">

                <TextView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:text="🆔"
                    android:textSize="11sp"
                    android:textColor="#8B4C4F" />

                <TextView
                    android:id="@+id/tvDriverId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DRV-2026-001"
                    android:textSize="13sp"
                    android:textColor="#8B4C4F"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- Email with Icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="2dp">

                <TextView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:text="📧"
                    android:textSize="11sp"
                    android:textColor="#8B4C4F" />

                <TextView
                    android:id="@+id/tvDriverEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@example.com"
                    android:textSize="13sp"
                    android:textColor="#8B4C4F"
                    android:layout_marginStart="6dp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Phone with Icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:text="📞"
                    android:textSize="11sp"
                    android:textColor="#8B4C4F" />

                <TextView
                    android:id="@+id/tvDriverPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="012-3456789"
                    android:textSize="13sp"
                    android:textColor="#8B4C4F"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Status Badge - Right Side -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvDriverStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#B5A36A"
                android:background="#F3E3E2"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:gravity="center" />

            <!-- Arrow Icon (Optional) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="24sp"
                android:textColor="#B5A36A"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>