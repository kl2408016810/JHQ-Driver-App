<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5E6E8"
    android:padding="8dp"
    tools:context=".AdminDashboardActivity">

    <!-- App Bar - Wine Theme -->
    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:background="@drawable/gradient_red_wine"
    android:paddingHorizontal="12dp"
    android:gravity="center_vertical"
    android:elevation="4dp">

<View
    android:layout_width="36dp"
    android:layout_height="36dp" />

<TextView
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:text=" ADMIN DASHBOARD"
    android:textColor="@android:color/white"
    android:textSize="18sp"
    android:textStyle="bold"
    android:gravity="center" />

<View
    android:layout_width="36dp"
    android:layout_height="36dp" />
</LinearLayout>

    <!-- Welcome Card - Wine Theme -->
    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:orientation="horizontal"
    android:background="#FDF1F2"
    android:padding="12dp"
    android:layout_marginTop="12dp"
    android:elevation="2dp"
    android:gravity="center_vertical"
    android:foreground="?android:attr/selectableItemBackground">

<TextView
android:layout_width="50dp"
android:layout_height="50dp"
android:text="👑"
android:textSize="30sp"
android:gravity="center"
android:background="#722F37"
android:textColor="@android:color/white"
android:layout_marginEnd="12dp" />

<LinearLayout
android:layout_width="0dp"
android:layout_height="wrap_content"
android:layout_weight="1"
android:orientation="vertical">

<TextView
    android:id="@+id/tvWelcome"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Welcome back,"
    android:textColor="#8B4C4F"
    android:textSize="12sp" />

<TextView
    android:id="@+id/tvAdminName"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Admin Name"
    android:textColor="#722F37"
    android:textSize="18sp"
    android:textStyle="bold" />
</LinearLayout>

<TextView
android:id="@+id/tvAdminId"
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="ADM-001"
android:textColor="#B5A36A"
android:textSize="12sp"
android:textStyle="bold"
android:background="#F3E3E2"
android:paddingHorizontal="12dp"
android:paddingVertical="4dp" />

    </LinearLayout>

    <!-- Stats Cards - Wine Theme -->
    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginTop="12dp">

<!-- Total Drivers -->
<LinearLayout
    android:layout_width="0dp"
    android:layout_height="85dp"
    android:layout_weight="1"
    android:layout_marginEnd="4dp"
    android:background="#F3E3E2"
    android:orientation="vertical"
    android:gravity="center"
    android:elevation="2dp"
    android:padding="8dp">

    <TextView
        android:id="@+id/tvTotalDrivers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="..."
        android:textColor="#722F37"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Drivers"
        android:textColor="#8B4C4F"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />
</LinearLayout>

<!-- Active Today -->
<LinearLayout
    android:layout_width="0dp"
    android:layout_height="85dp"
    android:layout_weight="1"
    android:layout_marginHorizontal="4dp"
    android:background="#F3E3E2"
    android:orientation="vertical"
    android:gravity="center"
    android:elevation="2dp"
    android:padding="8dp">

    <TextView
        android:id="@+id/tvActiveToday"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="..."
        android:textColor="#722F37"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Active"
        android:textColor="#8B4C4F"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />
</LinearLayout>

<!-- Pending -->
<LinearLayout
    android:layout_width="0dp"
    android:layout_height="85dp"
    android:layout_weight="1"
    android:layout_marginStart="4dp"
    android:background="#F3E3E2"
    android:orientation="vertical"
    android:gravity="center"
    android:elevation="2dp"
    android:padding="8dp">

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvPendingApprovals"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="..."
            android:textColor="#722F37"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/badgeApprovals"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_toEndOf="@id/tvPendingApprovals"
            android:layout_marginStart="2dp"
            android:background="#B5A36A"
            android:text="2"
            android:textColor="#722F37"
            android:textSize="8sp"
            android:textStyle="bold"
            android:gravity="center"
            android:visibility="gone" />
    </RelativeLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pending"
        android:textColor="#8B4C4F"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />
</LinearLayout>
</LinearLayout>

    <!-- Management Title - Wine -->
<TextView
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text=" MANAGEMENT "
android:textColor="#722F37"
android:textSize="14sp"
android:textStyle="bold"
android:layout_marginTop="16dp"
android:layout_marginBottom="8dp"
android:layout_gravity="center_horizontal"
android:background="#F3E3E2"
android:paddingHorizontal="12dp"
android:paddingVertical="4dp" />

    <!-- Management Cards -->
<LinearLayout
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:orientation="vertical">

<!-- Row 1 -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="12dp">

    <!-- All Drivers -->
    <LinearLayout
        android:id="@+id/cardAllDrivers"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_weight="1"
        android:layout_marginEnd="6dp"
        android:background="#FDF1F2"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="2dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:padding="8dp">

        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="🚛"
            android:textSize="32sp"
            android:gravity="center"
            android:background="#722F37"
            android:textColor="@android:color/white"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Drivers"
            android:textColor="#722F37"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Task Approvals -->
    <LinearLayout
        android:id="@+id/cardTaskApprovals"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_weight="1"
        android:layout_marginStart="6dp"
        android:background="#FDF1F2"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="2dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:padding="8dp">

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="✓✗"
                android:textSize="32sp"
                android:gravity="center"
                android:background="#722F37"
                android:textColor="@android:color/white"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/badgeApprovalsCard"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_alignTop="@id/cardTaskApprovals"
                android:layout_alignEnd="@id/cardTaskApprovals"
                android:layout_marginTop="-40dp"
                android:layout_marginEnd="-8dp"
                android:background="#B5A36A"
                android:text="2"
                android:textColor="#722F37"
                android:textSize="9sp"
                android:textStyle="bold"
                android:gravity="center"
                android:visibility="gone" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Approvals"
            android:textColor="#722F37"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>

    <!-- Row 2 - Admin Profile -->
    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_horizontal">

    <!-- Admin Profile -->
    <LinearLayout
        android:id="@+id/cardAdminProfile"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:layout_weight="0.5"
        android:background="#FDF1F2"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="2dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:padding="8dp">

        <TextView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="👤"
            android:textSize="32sp"
            android:gravity="center"
            android:background="#722F37"
            android:textColor="@android:color/white"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textColor="#722F37"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>

</LinearLayout>

    <!-- Divider - Wine Color -->
<View
android:layout_width="match_parent"
android:layout_height="1dp"
android:background="#F3E3E2"
android:layout_marginVertical="16dp" />

    <!-- Logout Button - Wine Theme -->
<Button
android:id="@+id/btnLogout"
android:layout_width="match_parent"
android:layout_height="45dp"
android:text="🚪 Logout"
android:textAllCaps="false"
android:textSize="16sp"
android:textStyle="bold"
android:background="@drawable/button_wine_gradient"
android:textColor="@android:color/white"
android:elevation="2dp" />

    <!-- Spacer -->
<View
android:layout_width="match_parent"
android:layout_height="0dp"
android:layout_weight="1" />

    </LinearLayout>