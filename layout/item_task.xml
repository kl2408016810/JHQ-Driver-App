<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="#FDF1F2">  <!-- Light pink background -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Title + Priority Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Task Title with Icon -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="📋"
                    android:textSize="16sp"
                    android:textColor="#722F37"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvTaskTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle Inspection"
                    android:textColor="#722F37"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Priority Badge - Wine Theme -->
            <TextView
                android:id="@+id/tvPriorityBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIGH"
                android:textColor="#722F37"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/badge_wine_light"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Task Description -->
        <TextView
            android:id="@+id/tvTaskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check tires, brakes, lights, and all fluid levels"
            android:textColor="#8B4C4F"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="12dp" />

        <!-- Info Row: Time + Category -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="12dp">

            <!-- Time Chip - Wine Theme -->
            <LinearLayout
                android:id="@+id/timeChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/chip_wine"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginEnd="12dp"
                android:gravity="center"
                android:minWidth="100dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🕘"
                    android:textSize="14sp"
                    android:textColor="#722F37"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvTaskTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08:00 AM"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Category Chip - Wine Theme -->
            <LinearLayout
                android:id="@+id/categoryChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/chip_wine_light"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:gravity="center"
                android:minWidth="100dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚗"
                    android:textSize="14sp"
                    android:textColor="#8B4C4F"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvTaskCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle"
                    android:textColor="#8B4C4F"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom Row: Status + Action -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <!-- Status Badge - Wine Theme -->
            <TextView
                android:id="@+id/tvTaskStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENDING"
                android:textColor="#722F37"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/badge_wine_light"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp" />

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Complete Button - Wine Theme -->
            <TextView
                android:id="@+id/tvCompleteAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓ APPROVE"
                android:textColor="#722F37"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/button_wine_outline"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:visibility="visible" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>