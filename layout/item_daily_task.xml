<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FDF1F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Time and Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Time with Icon -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:text="⏰"
                    android:textSize="14sp"
                    android:textColor="#B5A36A" />

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="09:00 AM"
                    android:textColor="#B5A36A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="PENDING"
                android:textColor="#722F37"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="#F3E3E2" />
        </LinearLayout>

        <!-- Row 2: Title with Icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="📋"
                android:textSize="16sp"
                android:textColor="#722F37" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sand Delivery"
                android:textColor="#722F37"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Row 3: Description -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Load 3 tons at Quarry"
            android:textColor="#8B4C4F"
            android:textSize="13sp"
            android:maxLines="2"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="8dp" />

        <!-- Row 4: Category and Arrival -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="32dp"
            android:layout_marginBottom="12dp">

            <!-- Category Badge -->
            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="Sand"
                android:textColor="#722F37"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="#F3E3E2"
                android:layout_marginEnd="8dp" />

            <!-- Arrival Badge -->
            <TextView
                android:id="@+id/tvArrival"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="NOT ARRIVED"
                android:textColor="#B5A36A"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="#F3E3E2" />
        </LinearLayout>

        <!-- Row 5: Complete Button -->
        <Button
            android:id="@+id/btnComplete"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="✅ SEND FOR APPROVAL"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/button_wine_gradient"
            android:visibility="gone"
            android:elevation="2dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>