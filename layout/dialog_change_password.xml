<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FDF1F2"
    android:elevation="8dp">

    <!-- Header with Icon Bulat -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <!-- Icon Bulat Sempurna -->
        <LinearLayout
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@drawable/circle_wine_bg"
            android:gravity="center"
            android:layout_marginEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒"
                android:textSize="24sp"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change Password"
                android:textColor="#722F37"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter your new password"
                android:textColor="#8B4C4F"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Current Password dengan Toggle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CURRENT PASSWORD"
        android:textColor="#722F37"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="4dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/edittext_wine_bg"
        android:padding="4dp"
        android:layout_marginBottom="16dp">

    <TextView
        android:id="@+id/ivCurrentLock"
        android:layout_width="40dp"
        android:layout_height="48dp"
        android:text="🔒"
        android:textSize="20sp"
        android:gravity="center"
        android:textColor="#722F37"
        android:layout_alignParentStart="true" />

    <EditText
        android:id="@+id/etCurrentPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_toStartOf="@id/ivCurrentToggle"
        android:layout_toEndOf="@id/ivCurrentLock"
        android:hint="Enter current password"
        android:inputType="textPassword"
        android:background="@null"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:textSize="14sp"
        android:textColor="#722F37"
        android:textColorHint="#B5A36A"/>

    <TextView
        android:id="@+id/ivCurrentToggle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentEnd="true"
        android:text="👁️"
        android:textSize="22sp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:textColor="#722F37" />
</RelativeLayout>

    <!-- New Password dengan Toggle -->
<TextView
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="NEW PASSWORD"
android:textColor="#722F37"
android:textSize="11sp"
android:textStyle="bold"
android:letterSpacing="0.05"
android:layout_marginBottom="4dp" />

<RelativeLayout
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:background="@drawable/edittext_wine_bg"
    android:padding="4dp"
    android:layout_marginBottom="16dp">

<TextView
android:id="@+id/ivNewLock"
android:layout_width="40dp"
android:layout_height="48dp"
android:text="🔒"
android:textSize="20sp"
android:gravity="center"
android:textColor="#722F37"
android:layout_alignParentStart="true" />

<EditText
android:id="@+id/etNewPassword"
android:layout_width="match_parent"
android:layout_height="48dp"
android:layout_toStartOf="@id/ivNewToggle"
android:layout_toEndOf="@id/ivNewLock"
android:hint="Min. 6 characters"
android:inputType="textPassword"
android:background="@null"
android:paddingStart="8dp"
android:paddingEnd="8dp"
android:textSize="14sp"
android:textColor="#722F37"
    android:textColorHint="#B5A36A" />

<TextView
android:id="@+id/ivNewToggle"
android:layout_width="48dp"
android:layout_height="48dp"
android:layout_alignParentEnd="true"
android:text="👁️"
android:textSize="22sp"
android:gravity="center"
android:clickable="true"
android:focusable="true"
android:textColor="#722F37" />
    </RelativeLayout>

    <!-- Confirm Password dengan Toggle -->
    <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="CONFIRM PASSWORD"
    android:textColor="#722F37"
    android:textSize="11sp"
    android:textStyle="bold"
    android:letterSpacing="0.05"
    android:layout_marginBottom="4dp" />

    <RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/edittext_wine_bg"
    android:padding="4dp"
    android:layout_marginBottom="24dp">

<TextView
android:id="@+id/ivConfirmLock"
android:layout_width="40dp"
android:layout_height="48dp"
android:text="🔒"
android:textSize="20sp"
android:gravity="center"
android:textColor="#722F37"
android:layout_alignParentStart="true" />

<EditText
android:id="@+id/etConfirmPassword"
android:layout_width="match_parent"
android:layout_height="48dp"
android:layout_toStartOf="@id/ivConfirmToggle"
android:layout_toEndOf="@id/ivConfirmLock"
android:hint="Re-enter new password"
android:inputType="textPassword"
android:background="@null"
android:paddingStart="8dp"
android:paddingEnd="8dp"
android:textSize="14sp"
android:textColor="#722F37"
    android:textColorHint="#B5A36A" />

<TextView
android:id="@+id/ivConfirmToggle"
android:layout_width="48dp"
android:layout_height="48dp"
android:layout_alignParentEnd="true"
android:text="👁️"
android:textSize="22sp"
android:gravity="center"
android:clickable="true"
android:focusable="true"
android:textColor="#722F37" />
    </RelativeLayout>

    <!-- Password Requirements Card - Rounded -->
    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/edittext_wine_bg"
    android:padding="12dp"
    android:layout_marginBottom="20dp">

<TextView
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="Password Requirements:"
android:textColor="#722F37"
android:textSize="12sp"
android:textStyle="bold"
android:layout_marginBottom="6dp" />

<TextView
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="✓ Minimum 6 characters"
android:textColor="#8B4C4F"
android:textSize="12sp"
android:layout_marginBottom="2dp" />

<TextView
android:layout_width="wrap_content"
android:layout_height="wrap_content"
android:text="✓ Use letters and numbers"
android:textColor="#8B4C4F"
android:textSize="12sp" />
    </LinearLayout>

    <!-- Action Buttons -->
<LinearLayout
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:orientation="horizontal">

<Button
    android:id="@+id/btnCancel"
    android:layout_width="0dp"
    android:layout_height="48dp"
    android:layout_weight="1"
    android:layout_marginEnd="6dp"
    android:text="Cancel"
    android:textAllCaps="false"
    android:textSize="14sp"
    android:textStyle="bold"
    android:background="@drawable/button_wine_gradient"
android:textColor="#FFFFFF" />

<Button
    android:id="@+id/btnUpdate"
    android:layout_width="0dp"
    android:layout_height="48dp"
    android:layout_weight="1"
    android:layout_marginStart="6dp"
    android:text="Update"
    android:textAllCaps="false"
    android:textSize="14sp"
    android:textStyle="bold"
    android:background="@drawable/button_wine_gradient"
android:textColor="@android:color/white" />
</LinearLayout>

    </LinearLayout>