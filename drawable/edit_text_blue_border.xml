<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background color -->
    <solid android:color="#F8F9FA" />

    <!-- Corner radius -->
    <corners android:radius="12dp" />

    <!-- Border stroke -->
    <stroke
        android:width="1.5dp"
        android:color="#1A237E" />

    <!-- Padding inside the edit text -->
    <padding
        android:left="16dp"
        android:top="8dp"
        android:right="16dp"
        android:bottom="8dp" />
</shape>